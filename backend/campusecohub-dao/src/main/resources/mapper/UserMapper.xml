<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusecohub.mapper.UserMapper">

    <select id="selectById" resultType="com.campusecohub.entity.User">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="selectByPhone" resultType="com.campusecohub.entity.User">
        SELECT * FROM user WHERE phone = #{phone}
    </select>

    <insert id="insert" parameterType="com.campusecohub.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, phone, wechat_openid, student_status, school_id, create_time, update_time)
        VALUES (#{username}, #{password}, #{phone}, #{wechatOpenid}, #{studentStatus}, #{schoolId}, NOW(), NOW())
    </insert>

</mapper>
