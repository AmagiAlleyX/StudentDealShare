<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusecohub.mapper.SchoolMapper">

    <select id="selectAll" resultType="com.campusecohub.entity.School">
        SELECT * FROM school
    </select>

    <select id="selectById" resultType="com.campusecohub.entity.School">
        SELECT * FROM school WHERE id = #{id}
    </select>

</mapper>
